{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/web",
      "dest": "/Learning/web.html"
    },
    {
      "src": "/llm",
      "dest": "/Learning/llm.html"
    },
    {
      "src": "/xss",
      "dest": "/XSS creator/index.html"
    },
    {
      "src": "/ghostname",
      "dest": "/GhostName/index.html"
    },
    {
      "src": "/dummy-uploads",
      "dest": "/Dummy Uploads/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
